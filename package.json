{
  "name": "agentbridge",
  "version": "1.2.0",
  "description": "AgentBridge — One endpoint for all your AI agent tools. Lean, powerful, HTTP + MCP dual protocol.",
  "type": "module",
  "scripts": {
    "dev": "node --env-file=.env --import tsx --watch src/index.ts",
    "start": "tsx src/index.ts",
    "mcp": "node --import tsx src/mcp.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/static": "^8.1.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.11.1",
    "fastify": "^5.8.5",
    "stripe": "^22.2.1",
    "uuid": "^11.1.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.15.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": "22.x"
  },
  "main": "server.js"
}
