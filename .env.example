# AgentBridge — Environment Variables
# Copy to .env and fill in your keys

PORT=3100
BASE_URL=http://localhost:3100

# Stripe
# 1. Create account at https://stripe.com
# 2. Get secret key: https://dashboard.stripe.com/apikeys
# 3. Create a single product ("Pro" - $5/mo): https://dashboard.stripe.com/products
# 4. Paste the price ID below
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRO_PRICE_ID=price_xxx

# Tool credentials (used when auth.source = "env")
OPENWEATHER_API_KEY=your_key_here
RESEND_API_KEY=your_key_here
